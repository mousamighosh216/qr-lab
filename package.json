{
  "name": "qrlab",
  "private": true,
  "workspaces": [
    "packages/*",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/qrcode": "^1.5.6",
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "canvas": "^3.2.3",
    "express": "^5.2.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
